#!/bin/bash
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
case "$HERE" in
  */freesurfer/bin) REPO_ROOT="$(cd "$HERE/../../.." && pwd)" ;;
  *) REPO_ROOT="$(cd "$HERE/.." && pwd)" ;;
esac
FS_CONTAINER="${REPO_ROOT}/containers/freesurfer-7.4.1.sif"
LICENSE_DIR="${REPO_ROOT}/freesurfer_license"
MELD_DATA="${REPO_ROOT}/meld_graph/meld_data"
CMD_NAME="mri_vol2surf"

# Always use MELD's standard subjects directory  
SUBJ_DIR="$MELD_DATA/output/fs_outputs"
apptainer exec \
    --bind "$MELD_DATA:$MELD_DATA" \
    --bind "$LICENSE_DIR:/license" \
    --env FS_LICENSE=/license/license.txt \
    --env FREESURFER_HOME=/usr/local/freesurfer \
    "$FS_CONTAINER" \
    bash -c "source /usr/local/freesurfer/SetUpFreeSurfer.sh > /dev/null && export SUBJECTS_DIR='$SUBJ_DIR' && $CMD_NAME \"\$@\"" -- "$@"

