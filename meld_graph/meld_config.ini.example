[DEFAULT]
; Copy this file to meld_config.ini (see .gitignore — that file is local-only).
; Use an absolute path, or a path relative to the meld_graph/ directory (e.g. meld_data).
meld_data_path = /data

[develop]
; do not change
base_path = %(meld_data_path)s/output/preprocessed_surf_data
experiment_path = %(meld_data_path)s/models
fs_subjects_path = %(meld_data_path)s/output/fs_outputs
meld_params_path = %(meld_data_path)s/meld_params
