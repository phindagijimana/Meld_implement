# Optional. Rename to production.env only if you split the bundle across paths.
# With the standard layout you need NO file: meld-docker and meld_production.sh infer
# everything from the folder they live in (MELD_DEPLOY_ROOT).
#
# Standard layout (portable — copy this whole directory anywhere):
#   docker_version/
#     meld-docker  meld_production.sh (optional wrapper → meld-docker cohort)
#     meld_graph_v2.2.4.sif
#     freesurfer_license.txt  meld_license.txt
#     meld_data/
#       input/  output/  logs/  locks/  models/  meld_params/
#       Meld_Owen/  (cohorts with sub-*/anat/*_T1w.nii.gz)
#
# ---------------------------------------------------------------------------
# Split-root example (scripts + image on volume A, heavy data on volume B):
#   export MELD_DEPLOY_ROOT=/path/to/docker_version    # scripts + .sif + licenses + models
#   MELD_DATA_DIR=/path/to/meld_data                   # input/output/cohorts only on NFS
#   MODELS_SRC=${MELD_DEPLOY_ROOT}/meld_data/models
#   MELD_PARAMS_SRC=${MELD_DEPLOY_ROOT}/meld_data/meld_params
#
# Or point assets explicitly (still no need for absolute paths if you use variables):
#   MELD_CONTAINER_IMAGE=${MELD_DEPLOY_ROOT}/meld_graph_v2.2.4.sif
#   MELD_FS_LICENSE=${MELD_DEPLOY_ROOT}/freesurfer_license.txt
#   MELD_MELD_LICENSE=${MELD_DEPLOY_ROOT}/meld_license.txt
#
# ---------------------------------------------------------------------------
# SLURM (optional)
# SLURM_MEM=64G
# SLURM_CPUS_PER_TASK=8
# SLURM_TIME_LIMIT=24:00:00
# SLURM_PARTITION=general
# SLURM_MAIL_USER=you@institution.edu
# SLURM_MAIL_TYPE=END,FAIL
